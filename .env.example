# Supabase project credentials.
# Find these in your Supabase dashboard: Project Settings -> API.
# VITE_SUPABASE_URL is the "Project URL".
# VITE_SUPABASE_PUBLISHABLE_KEY is the "anon"/"publishable" key (safe for the browser; RLS protects your data).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# Comma-separated emails allowed to see the "Clear all data" danger zone.
# Note: VITE_ vars ship to the browser bundle, so this is cosmetic, not secret.
VITE_OWNER_EMAILS=you@example.com
